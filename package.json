{
  "name": "autopi",
  "version": "0.1.0",
  "description": "AutoPi: Pi-native interactive autopilot package with a shared headless driver",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/archpeng/pi-sdk.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "sdk",
    "extension",
    "agent",
    "autopilot"
  ],
  "bin": {
    "pi-sdk-autopilot": "./dist/sdk/orchestrator.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "skills",
    "README.md",
    "docs/runbooks"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "clean": "rm -rf dist",
    "dev": "tsx src/sdk/orchestrator.ts",
    "smoke:pi-autoload": "node ./scripts/pi-startup-autoload-proof.mjs",
    "smoke:pi-commands": "node ./scripts/pi-command-smoke.mjs",
    "smoke:pi-bb-backed": "node ./scripts/pi-bb-backed-smoke.mjs",
    "smoke:packaged-install": "node ./scripts/packaged-install-smoke.mjs",
    "release:check": "node ./scripts/release-readiness-check.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.71.1",
    "@mariozechner/pi-coding-agent": "^0.71.1",
    "typebox": "^1.1.35"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
